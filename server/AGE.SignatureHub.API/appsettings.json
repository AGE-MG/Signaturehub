{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=signaturehub;Username=postgres;Password=1311"
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "a8a9de9295b5b46670ad124a7a315d8349923f6258670b3a7a450737db6b6fec",
    "Issuer": "AGE.SignatureHub",
    "Audience": "AGE.SignatureHub.API",
    "ExpirationInMinutes": 60
  },
  "ApplicationSettings": {
    "ApplicationName": "AGE SignatureHub",
    "ApplicationUrl": "https://localhost:5001",
    "MaxDocumentSizeInMB": 50,
    "DocumentExpirationInDays": 30,
    "EnableEmailNotifications": true,
    "EnableWebhooks": false,
    "BaseUrl": "https://localhost:5001",
    "SignatureUrlPath": "/sign",
    "Email": {
      "FromEmail": "noreply@signaturehub.com",
      "FromName": "SignatureHub"
    },
    "Webhook": {
      "DefaultEndpoint": "",
      "TimeoutSeconds": 30
    }
  },
  "Storage": {
    "Provider": "LocalFileSystem",
    "LocalPath": "./Storage",
    "ConnectionString": "",
    "ContainerName": "documents"
  },
  "Email": {
    "SmtpServer": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "your_smtp_user_here",
    "SenderName": "your_smtp_password_here",
    "Username": "your_smtp_user_here",
    "Password": "your_smtp_password_here",
    "UseSsl": true
  },
  "Webhooks": {
    "Endpoints": [
      {
        "Name": "Internal System",
        "Url": "https://intranet.advocaciageral.mg.gov.br/webhooks/signatures",
        "Secret": "192be813143ddfc039dc1040ce54d5817cb7fe64cdc6de8a2f965ee9119d2030",
        "Events": [ "signature.completed", "signature.rejected" ]
      }
    ]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "AGE.SignatureHub.API"
    }
  }
}
